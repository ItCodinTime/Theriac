VULTR_INFERENCE_API_KEY=your_vultr_inference_api_key_here
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
VULTR_MAIN_MODEL=nvidia/Nemotron-Cascade-2-30B-A3B
VULTR_FALLBACK_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16
VULTR_TOOL_MODEL=replace_with_a_tool_capable_model_from_v1_models
VULTR_RAG_MODEL=qwen2.5-32b-instruct
VULTR_MAX_TOKENS=1200
VULTR_TEMPERATURE=0.2
VULTR_INFERENCE_TIMEOUT=60

# ---------------------------------------------------------------------------
# Supermemory — PRIMARY memory / RAG engine (self-hosted, local, zero-egress).
# Single binary on localhost:6767 with an embedded graph engine + local
# embeddings. Retrieval never leaves the host; only the extraction LLM is pointed
# at Vultr inference. Launch it wired to Vultr with:
#   OPENAI_BASE_URL=$VULTR_INFERENCE_BASE_URL \
#   OPENAI_API_KEY=$VULTR_INFERENCE_API_KEY \
#   OPENAI_MODEL=$VULTR_MAIN_MODEL \
#   npx supermemory local          # or: curl -fsSL https://supermemory.ai/install | bash
# SUPERMEMORY_API_KEY is printed by the server on first boot (blank = unauth localhost).
SUPERMEMORY_BASE_URL=http://localhost:6767
SUPERMEMORY_API_KEY=
SUPERMEMORY_TIMEOUT=30
SUPERMEMORY_SEARCH_LIMIT=5
# When true, mirror sealed manual/CVE records into the legacy Vultr Vector Store
# (below) as an optional archive tier. Primary retrieval always uses Supermemory.
VULTR_ARCHIVE_ENABLED=false

# ---------------------------------------------------------------------------
# Vultr Vector Store — legacy, now the OPTIONAL sealed-evidence archive tier.
# Only used when VULTR_ARCHIVE_ENABLED=true.
VULTR_API_KEY=your_vultr_main_api_key_here
# Vector store uses VULTR_API_KEY (main account). Inference uses VULTR_INFERENCE_API_KEY.
VULTR_VECTOR_STORE_URL=https://api.vultrinference.com/v1/vector_store
VULTR_VECTOR_COLLECTION_ID=
VULTR_VECTOR_COLLECTION_NAME=panacea-manuals
VULTR_CVE_COLLECTION_ID=your_vultr_cve_collection_id
VULTR_CVE_COLLECTION_NAME=panacea-cves
VULTR_VECTOR_CHUNK_SIZE=2000
VULTR_VECTOR_CHUNK_OVERLAP=200
VULTR_VECTOR_TIMEOUT=30
VULTR_VPC_ID=vpc-medical-01
VULTR_NAT_GATEWAY_ID=your_managed_nat_gateway_id
VULTR_DEVICE_PRIVATE_IP=10.0.0.10
VULTR_ALLOWED_SOURCE_SUBNET=0.0.0.0
VULTR_ALLOWED_SOURCE_SUBNET_SIZE=0
VULTR_POLICY_LEASE_SECONDS=900
VULTR_NETWORK_TIMEOUT=20
VULTR_NETWORK_PROBE_HOST=
VULTR_NETWORK_PROBE_TIMEOUT=2

# Set true in Vultr deployment. Missing Kafka, Object Storage, or OIDC then fails closed.
VULTR_NATIVE_STRICT=false

# Vultr Object Storage. Create the evidence bucket with Object Lock enabled.
VULTR_OBJECT_STORAGE_ENDPOINT=https://your-region.vultrobjects.com
VULTR_OBJECT_STORAGE_REGION=us-east-1
VULTR_OBJECT_STORAGE_ACCESS_KEY=your_access_key
VULTR_OBJECT_STORAGE_SECRET_KEY=your_secret_key
VULTR_MANUAL_BUCKET=panacea-manuals
VULTR_EVIDENCE_BUCKET=panacea-evidence
VULTR_EVIDENCE_RETENTION_DAYS=365

# Vultr Managed Database (PostgreSQL). Durably persists policy leases (so an
# active firewall lease survives a backend restart instead of being silently
# forgotten) and the evidence-bundle index used by GET /api/v1/evidence/{id}.
# Leave blank to keep leases/evidence-lookup in-memory only (dev/demo mode).
VULTR_DATABASE_URL=

# Vultr Managed Kafka with Schema Registry enabled.
VULTR_KAFKA_BOOTSTRAP_SERVERS=host:9093
VULTR_KAFKA_SECURITY_PROTOCOL=SASL_SSL
VULTR_KAFKA_SASL_MECHANISM=SCRAM-SHA-256
VULTR_KAFKA_USERNAME=your_kafka_user
VULTR_KAFKA_PASSWORD=your_kafka_password
VULTR_KAFKA_CA_FILE=
VULTR_SCHEMA_REGISTRY_URL=https://your-schema-registry-endpoint

# Vultr IAM OIDC for uploads, execution, and human override.
VULTR_OIDC_ISSUER=https://your-vultr-oidc-issuer
VULTR_OIDC_AUDIENCE=panacea
PANACEA_OPERATOR_ROLE=panacea-operator
PANACEA_CORS_ORIGINS=http://localhost:3000
